# Normaliza finales de línea por tipo de script para que funcionen en cada SO.
*.command  text eol=lf
*.sh       text eol=lf
*.ps1      text eol=crlf
*.bat      text eol=crlf
*.md       text
LICENSE    text
*.py       text eol=lf
*.b64      text eol=lf
# Binarios (sin normalización de fin de línea)
*.png      binary
*.ico      binary
